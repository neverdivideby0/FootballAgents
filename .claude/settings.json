{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "in=$(cat); echo \"$in\" | grep -q 'git commit' && (cd /Users/bryanlee/Desktop/SideProjects/ClaudeCode/WorldCupAgents && echo \"$in\" | .venv/bin/python scripts/check_docs.py); true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/bryanlee/Desktop/SideProjects/ClaudeCode/WorldCupAgents && uv run pytest -q --tb=short 2>&1 | tail -20"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude finished\" with title \"FootballAgents\"'"
          }
        ]
      }
    ]
  }
}
