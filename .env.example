# Copy to .env and fill in what you need. The app runs with NO keys (baseline path).

# --- LLM provider keys (set the one matching your --provider choice) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=

# --- Football data vendor (free tier) ---
FOOTBALL_DATA_ORG_TOKEN=        # https://www.football-data.org/ (free tier)

# --- Live betting market shown to the judge (free tier ~500 req/mo) ---
ODDS_API_KEY=                   # https://the-odds-api.com/ — de-vigged bookmaker consensus for predict/dossier/odds

# --- Match commentary (free tier) ---
GUARDIAN_API_KEY=               # https://open-platform.theguardian.com/access/ (free developer key)

# --- Richer per-player stats: passing accuracy, key passes, rating (free tier) ---
API_FOOTBALL_KEY=               # https://www.api-football.com/ (free: ~100 req/day). fetch-data auto-prefers this.

# --- Config overrides (optional; CLI flags take precedence) ---
# WCA_COMMENTARY_VENDOR=guardian  # or 'placeholder' (auto: guardian when GUARDIAN_API_KEY set)
# WCA_USE_LLM=true                # turn on LLM agents by default
# WCA_LLM_PROVIDER=deepseek       # anthropic | openai | google | deepseek
# WCA_DEEP_THINK_LLM=deepseek-reasoner
# WCA_QUICK_THINK_LLM=deepseek-chat
# WCA_MAX_DEBATE_ROUNDS=2
# WCA_ENSEMBLE_JUDGE_WEIGHT=0.6
# WCA_USE_STATS_LAMBDA=true       # fitted-strength goals model (default on; set false for rank-Elo)
# WCA_DATA_VENDOR=football_data_org   # or 'placeholder'
